      "use": [
        "cover",
        "closing"
      ]
    },
    {
      "id": "andromeda",
      "kind": "image",
      "src": "backgrounds/andromeda.jpg",
      "opacity": 0.55,
      "use": [
        "divider"
      ]
    },
    {
      "id": "lagoon",
      "kind": "image",
      "src": "backgrounds/lagoon.jpg",
      "opacity": 0.5,
      "use": [
        "content"
      ]
    }
  ],
  "motifs": [
    {
      "id": "ab-blob",
      "role": "accent",
      "placement": "top-right"
    },
    {
      "id": "ab-scatter",
      "role": "accent",
      "placement": "bottom-left"
    }
  ],
  "elements": [
    {
      "src": "elements/cassiopeia.jpg",
      "alt": "Cassiopeia A supernova remnant",
      "license": "PD (NASA)"
    }
  ],
  "treatments": {
    "cover": {
      "background": "cassiopeia",
      "motifs": [
        "ab-blob"
      ]
    },
    "divider": {
