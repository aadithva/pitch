{
  "id": "abstract",
  "name": "Abstract",
  "mode": "dark",
  "tagline": "Cosmic color fields, organic blobs, gradient mesh.",
  "recommendWhen": "Creative, AI/ML, design, or innovation stories — depth without literal imagery.",
  "palette": {
    "background": "#0B0B12",
    "surface": "#16131F",
    "text": "#F4F1EA",
    "muted": "#9A93A8",
    "primary": "#5B8DEF",
    "secondary": "#2E8B6A",
    "accent": "#E8630A",
    "highlight": "#F2C12E"
  },
  "fonts": {
    "heading": "'Bebas Neue', Impact, sans-serif",
    "body": "'DM Sans', system-ui, sans-serif",
    "mono": "'Space Mono', ui-monospace, monospace"
  },
  "fontWeights": {
    "heading": 400,
    "body": 400
  },
  "googleFonts": [
    "Bebas+Neue",
    "DM+Sans:wght@400;500",
    "Space+Mono"
  ],
  "backgrounds": [
    {
      "id": "mesh",
